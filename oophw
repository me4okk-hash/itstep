class Book:
    def __init__(self, title, authors, year):
        self.title = title
        self.authors = authors
        self.year = year

    def __str__(self):
        authors_str = ", ".join(self.authors)
        return f"'{self.title}' ({self.year}), автори: {authors_str}"


class Library:
    def __init__(self, name, address):
        self.name = name
        self.address = address
        self.books = []

    def __str__(self):
        return f"Бібліотека '{self.name}', адреса: {self.address}, книг: {len(self.books)}"

    def show_books(self):
        if not self.books:
            print("Книг нема у бiблiотецi")
        else:
            for i, book in enumerate(self.books, 1):
                print(f"{i}. {book}")

    def add_book(self, book):
        self.books.append(book)
        print("Книгу додано у бiблiотеку")

    def remove_book(self, title):
        for book in self.books:
            if book.title.lower() == title.lower():
                self.books.remove(book)
                print("Книгу видалено")
                return
        print("Книги нема")

    def find_by_title(self, title):
        found = [book for book in self.books if title.lower() in book.title.lower()]
        if found:
            for book in found:
                print(book)
        else:
            print("Книга не знайдена")

    def find_by_author(self, author):
        found = [book for book in self.books if any(author.lower() in a.lower() for a in book.authors)]
        if found:
            for book in found:
                print(book)
        else:
            print("Книгу автора не знайдено")


def menu():
    library = Library("Бiблiотека Максима", "Одеса")

    while True:
        print("=== Меню ===")
        print("1. Показати книги")
        print("2. Додати книгу")
        print("3. Видалити книгу")
        print("4. Пошук за назвою")
        print("5. Пошук за автором")
        print("0. Вихід")

        choice = input("Оберiть дiю: ")

        match choice:
            case "1":
                library.show_books()

            case "2":
                title = input("Назва книги: ")
                authors = input("Автори (через кому): ").split(",")
                authors = [a.strip() for a in authors]
                year = int(input("Рік: "))
                book = Book(title, authors, year)
                library.add_book(book)

            case "3":
                title = input("Введіть назву книги для видалення: ")
                library.remove_book(title)

            case "4":
                title = input("Введіть назву для пошуку: ")
                library.find_by_title(title)

            case "5":
                author = input("Введіть автора: ")
                library.find_by_author(author)

            case "0":
                print("Вихід...")
                break

            case _:
                print("Невірний вибір.")


if __name__ == "__main__":
    menu()
